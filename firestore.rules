rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function sessionPath(sessionId) {
      return /databases/$(database)/documents/sessions/$(sessionId);
    }

    function sessionDoc(sessionId) {
      return get(sessionPath(sessionId));
    }

    function sessionExists(sessionId) {
      return exists(sessionPath(sessionId));
    }

    function techDocPath(uid) {
      return /databases/$(database)/documents/techs/$(uid);
    }

    function isActiveTechUser(uid) {
      return signedIn()
        && exists(techDocPath(uid))
        && get(techDocPath(uid)).data.active != false;
    }

    function isClient(sessionId) {
      return signedIn()
        && sessionExists(sessionId)
        && sessionDoc(sessionId).data.clientUid == request.auth.uid;
    }

    function isTech(sessionId) {
      return signedIn()
        && sessionExists(sessionId)
        && isActiveTechUser(request.auth.uid)
        && (
          (sessionDoc(sessionId).data.tech != null
            && sessionDoc(sessionId).data.tech.techUid == request.auth.uid)
          || sessionDoc(sessionId).data.techUid == request.auth.uid
        );
    }

    function isSessionMember(sessionId) {
      return isClient(sessionId) || isTech(sessionId);
    }

    match /sessions/{sessionId} {

      function canBindLegacyClientUid() {
        return signedIn()
          && resource.data.clientUid == null
          && request.resource.data.clientUid == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['clientUid', 'updatedAt']);
      }

      function clientCanUpdateSession() {
        return isClient(sessionId)
          && request.resource.data.clientUid == resource.data.clientUid
          && request.resource.data.requestId == resource.data.requestId
          && request.resource.data.clientId == resource.data.clientId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.techUid == resource.data.techUid
          && request.resource.data.tech == resource.data.tech
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'client',
            'clientUid',
            'state',
            'telemetry',
            'updatedAt',
            'status',
            'closedAt'
          ])
          && (
            request.resource.data.status == resource.data.status
            || request.resource.data.status == 'closed'
          );
      }

      allow list: if false;
      allow get: if isSessionMember(sessionId);

      allow create: if signedIn()
        && request.resource.data.clientUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'clientUid',
          'client',
          'state',
          'telemetry',
          'createdAt',
          'updatedAt',
          'status',
          'closedAt'
        ]);

      allow update: if clientCanUpdateSession() || canBindLegacyClientUid();
      allow delete: if false;

      match /messages/{docId} {
        allow read, write: if isSessionMember(sessionId);
      }

      match /events/{docId} {
        allow read, write: if isSessionMember(sessionId);
      }

      match /call/{docId} {
        allow read, write: if isSessionMember(sessionId);
      }

      match /call_ice_client/{docId} {
        allow read, write: if isSessionMember(sessionId);
      }

      match /call_ice_tech/{docId} {
        allow read, write: if isSessionMember(sessionId);
      }
    }
  }
}
