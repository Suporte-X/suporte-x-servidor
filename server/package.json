{
  "name": "suporte-x-servidor",
  "version": "1.0.0",
  "description": "Screen-share (view-only) with WebRTC + Socket.IO. Sender (Android browser) shares screen via getDisplayMedia; viewer watches in a browser.",
  "main": "server.js",
  "scripts": {
    "firebase:doctor": "node scripts/firebaseDoctor.js",
    "firebase:tech:create": "node scripts/createTechUser.js",
    "firebase:tech:claim": "node scripts/setTechClaim.js",
    "firestore:cleanup:dry": "node scripts/firestoreRetentionCleanup.mjs",
    "firestore:cleanup:execute": "node scripts/firestoreRetentionCleanup.mjs --execute",
    "privacy:requests": "node scripts/privacyDeletionRequests.mjs",
    "test": "node -e \"const fs=require('node:fs'),cp=require('node:child_process');const files=fs.readdirSync('test').filter(f=>f.endsWith('.test.js')).map(f=>'test/'+f);const result=cp.spawnSync(process.execPath,['--test',...files],{stdio:'inherit'});process.exit(result.status??1)\"",
    "test:upload": "node --test test/uploadRouter.test.js",
    "start": "node server.js",
    "dev": "node server.js"
  },
  "dependencies": {
    "aws-jwt-verify": "5.2.1",
    "cors": "^2.8.5",
    "express": "4.22.2",
    "firebase-admin": "13.10.0",
    "multer": "2.2.0",
    "pdfkit": "0.19.1",
    "socket.io": "4.8.3"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "overrides": {
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "supertest": "^7.2.2"
  }
}
