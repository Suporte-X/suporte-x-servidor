{
  "name": "suporte-x-servidor",
  "version": "1.0.0",
  "description": "Screen-share (view-only) with WebRTC + Socket.IO. Sender (Android browser) shares screen via getDisplayMedia; viewer watches in a browser.",
  "main": "server.js",
  "scripts": {
    "firebase:doctor": "node scripts/firebaseDoctor.js",
    "firebase:tech:create": "node scripts/createTechUser.js",
    "firebase:tech:claim": "node scripts/setTechClaim.js",
    "start": "node server.js",
    "dev": "node server.js"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "nanoid": "^5.0.7"
  },
  "engines": {
    "node": ">=18"
  }
}
