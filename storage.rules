rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // DEV: libera uploads/reads de mídia das sessões para usuários autenticados.
    // Cobre caminhos usados hoje pelo app/web:
    // sessions/{id}/audio/*
    // sessions/{id}/attachments/*
    // sessions/{id}/images/*
    match /sessions/{sessionId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Compatibilidade com caminho legado.
    match /chat/{sessionId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
