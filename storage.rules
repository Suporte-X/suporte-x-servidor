rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function hasSafePayload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType != null
        && request.resource.contentType.matches('[a-zA-Z0-9.+-]+/[a-zA-Z0-9.+-]+');
    }

    function isImage() {
      return request.resource != null
        && request.resource.contentType != null
        && request.resource.contentType.matches('image/.*');
    }

    // Midia de chat/suporte por sessao
    match /sessions/{sessionId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && hasSafePayload(25 * 1024 * 1024);
    }

    // Caminho legado de midia por sessao
    match /chat/{sessionId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && hasSafePayload(25 * 1024 * 1024);
    }

    // Avatares de tecnicos
    match /chat/avatars/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && isImage()
        && request.resource.size < 6 * 1024 * 1024
        && request.resource.metadata.ownerUid == request.auth.uid;
    }
  }
}
